{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "timezone": "Asia/Dushanbe",
  "schedule": ["before 9am on Monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchPackageNames": ["react", "react-dom"],
      "groupName": "React core"
    },
    {
      "matchPackageNames": ["vite", "@vitejs/plugin-react", "@tailwindcss/vite", "tailwindcss"],
      "groupName": "Vite + Tailwind toolchain"
    },
    {
      "matchPackageNames": ["@tanstack/react-query", "@tanstack/react-query-devtools"],
      "groupName": "TanStack Query"
    },
    {
      "matchPackageNames": ["typescript", "typescript-eslint", "eslint", "@eslint/js"],
      "groupName": "TypeScript + ESLint"
    }
  ],
  "ignorePaths": ["node_modules", "dist"]
}
