@page "/banners"
@attribute [Authorize(Roles = "SuperAdmin")]

@inject ContentService ContentService
@inject ISnackbar Snackbar
@inject DialogHelper DialogHelper

<PageTitle>FlowerHouse — Баннеры</PageTitle>

<PageHeader Title="Баннеры" Subtitle="Управление рекламными баннерами на главной странице приложения">
    <Actions>
        <button @onclick="OpenCreate" 
                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-semibold shadow-sm transition-colors flex items-center gap-1.5">
            <LucideIcon Name="plus" Class="w-4 h-4" />
            <span>Добавить баннер</span>
        </button>
    </Actions>
</PageHeader>

@if (_loading)
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @for (var i = 0; i < 3; i++)
        {
            <div class="h-64 rounded-2xl bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 p-4 skeleton"></div>
        }
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var banner in _banners.OrderBy(b => b.SortOrder))
        {
            var b = banner;
            <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all flex flex-col group theme-transition">
                @* Изображение / Заглушка *@
                <div class="relative overflow-hidden">
                    @if (!string.IsNullOrEmpty(b.ImageUrl))
                    {
                        <img src="@b.ImageUrl" alt="@b.Title" class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-300" />
                    }
                    else
                    {
                        <div class="h-40 bg-gradient-to-tr from-violet-500 to-pink-500 flex items-center justify-center text-white/50">
                            <LucideIcon Name="image" Class="w-8 h-8 text-white/80" />
                        </div>
                    }
                    <div class="absolute top-3 right-3">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-bold shadow-sm @(b.IsActive ? "bg-emerald-500 text-white" : "bg-slate-500 text-white")">
                            @(b.IsActive ? "Активен" : "Скрыт")
                        </span>
                    </div>
                </div>

                @* Контент *@
                <div class="p-5 flex-1 flex flex-col justify-between">
                    <div>
                        <h3 class="font-bold text-slate-800 dark:text-zinc-200 text-sm">@b.Title</h3>
                        <div class="flex items-center gap-1.5 text-[10px] text-slate-400 dark:text-zinc-500 mt-2 font-medium">
                            <LucideIcon Name="hash" Class="w-3 h-3" />
                            <span>Порядок: @b.SortOrder</span>
                            @if (!string.IsNullOrEmpty(b.LinkUrl))
                            {
                                <span>•</span>
                                <span class="truncate max-w-[150px]">@b.LinkUrl</span>
                            }
                        </div>
                    </div>

                    @* Кнопки управления *@
                    <div class="flex items-center justify-between border-t border-slate-100 dark:border-zinc-800/60 mt-4 pt-3">
                        <button @onclick="() => OpenEdit(b)" 
                                class="px-3 py-1.5 bg-slate-50 hover:bg-slate-100 dark:bg-zinc-800 dark:hover:bg-zinc-800/80 border border-slate-200 dark:border-zinc-700/50 rounded-lg text-xs font-semibold text-slate-600 dark:text-zinc-300 transition-colors flex items-center gap-1">
                            <LucideIcon Name="edit" Class="w-3 h-3" />
                            <span>Изменить</span>
                        </button>
                        <button @onclick="() => Delete(b)" 
                                class="p-1.5 text-slate-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-slate-50 dark:hover:bg-zinc-800 rounded-md transition-colors">
                            <LucideIcon Name="trash" Class="w-4 h-4" />
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<UiModal IsOpen="_dialogVisible" Title="@(_editing != null ? "Редактировать баннер" : "Создать баннер")" OnClose="() => _dialogVisible = false">
    <ChildContent>
        <div class="space-y-4 pt-2">
            <MudTextField T="string" @bind-Value="_title" Label="Заголовок баннера" Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField T="string" @bind-Value="_linkUrl" Label="URL ссылки (клик на баннер)" Variant="Variant.Outlined" Class="mb-3" />
            <MudNumericField T="int" @bind-Value="_sortOrder" Label="Порядок сортировки" Variant="Variant.Outlined" Min="0" Class="mb-3" />
            
            <div class="flex items-center justify-between py-2 border-t border-slate-100 dark:border-zinc-800/50 mt-4">
                <span class="text-xs font-semibold text-slate-500 dark:text-zinc-400">Активен</span>
                <MudSwitch T="bool" @bind-Value="_active" Color="Color.Success" />
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button @onclick="() => _dialogVisible = false" 
                class="px-4 py-2 border border-slate-200 dark:border-zinc-800 rounded-lg text-xs font-semibold text-slate-600 dark:text-zinc-300 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
            Отмена
        </button>
        <button @onclick="Save" 
                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-semibold shadow-sm transition-colors">
            Сохранить
        </button>
    </FooterContent>
</UiModal>

@code {
    private bool _loading = true;
    private List<BannerDto> _banners = [];
    private bool _dialogVisible; 
    private BannerDto? _editing;
    private string _title = ""; 
    private string? _linkUrl; 
    private int _sortOrder; 
    private bool _active = true;

    protected override async Task OnInitializedAsync() { await LoadData(); }
    private async Task LoadData() { _loading=true; _banners=await ContentService.GetBannersAsync()??[]; _loading=false; }

    private void OpenCreate() { _editing=null; _title=""; _linkUrl=null; _sortOrder=_banners.Count; _active=true; _dialogVisible=true; }
    private void OpenEdit(BannerDto b) { _editing=b; _title=b.Title; _linkUrl=b.LinkUrl; _sortOrder=b.SortOrder; _active=b.IsActive; _dialogVisible=true; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Заголовок обязателен", Severity.Warning);
            return;
        }

        var content = new MultipartFormDataContent();
        content.Add(new StringContent(_title), "title");
        content.Add(new StringContent(_linkUrl??""), "linkUrl");
        content.Add(new StringContent(_sortOrder.ToString()), "sortOrder");
        content.Add(new StringContent(_active.ToString()), "isActive");

        var ok = _editing!=null
            ? await ContentService.UpdateBannerAsync(_editing.Id, content)
            : await ContentService.CreateBannerAsync(content);

        Snackbar.Add(ok ? "Баннер сохранён" : "Ошибка", ok ? Severity.Success : Severity.Error);
        _dialogVisible = false;
        if (ok) await LoadData();
    }

    private async Task Delete(BannerDto b)
    {
        if (!await DialogHelper.ConfirmAsync($"Удалить баннер \"{b.Title}\"?")) return;
        var ok = await ContentService.DeleteBannerAsync(b.Id);
        Snackbar.Add(ok ? "Удалено" : "Ошибка", ok ? Severity.Success : Severity.Error);
        if (ok) await LoadData();
    }
}
