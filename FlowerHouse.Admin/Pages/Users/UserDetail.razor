@page "/users/{Id:int}"
@attribute [Authorize(Roles = "SuperAdmin")]

@inject UserService UserService
@inject ISnackbar Snackbar
@inject DialogHelper DialogHelper

<PageTitle>FlowerHouse — Пользователь</PageTitle>

<PageHeader Title="@(_user?.Name ?? "Профиль пользователя")"
            BreadcrumbItems="@(new List<BreadcrumbItem> {
                new("Пользователи", "/users", icon: Icons.Material.Filled.People),
                new(_user?.Phone ?? "...", null, true) })" />

@if (_loading)
{
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start skeleton h-96 rounded-2xl bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 p-6"></div>
}
else if (_user == null)
{
    <div class="p-4 bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900/30 text-rose-600 dark:text-rose-400 text-xs rounded-xl flex items-center gap-2">
        <LucideIcon Name="alert-triangle" Class="w-4 h-4 shrink-0" />
        <span>Пользователь не найден</span>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
        @* Информация о пользователе *@
        <div class="md:col-span-8 bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-2xl p-6 shadow-sm theme-transition">
            <h3 class="text-sm font-bold text-slate-800 dark:text-zinc-200 mb-6 flex items-center gap-2">
                <LucideIcon Name="user" Class="w-4 h-4 text-indigo-500" />
                <span>Личные данные</span>
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 select-none">
                <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-zinc-500">Номер телефона</span>
                    <span class="font-semibold text-slate-800 dark:text-zinc-200 text-sm">@_user.Phone</span>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-zinc-500">Имя</span>
                    <span class="font-semibold text-slate-800 dark:text-zinc-200 text-sm">@(_user.Name ?? "—")</span>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-zinc-500">Роль в системе</span>
                    <div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold @(GetRoleBadgeClass(_user.Role))">
                            @_user.Role
                        </span>
                    </div>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-zinc-500">Дата регистрации</span>
                    <span class="font-semibold text-slate-800 dark:text-zinc-200 text-sm">@_user.CreatedAt.ToString("dd.MM.yyyy")</span>
                </div>
            </div>

            @* Метрики активности *@
            <div class="grid grid-cols-2 gap-4 border-t border-slate-100 dark:border-zinc-800/60 mt-8 pt-6">
                <div class="bg-slate-50 dark:bg-zinc-950/20 rounded-xl p-4 border border-slate-100 dark:border-zinc-800/40">
                    <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-zinc-500 block">Всего заказов</span>
                    <span class="text-3xl font-extrabold text-indigo-600 dark:text-violet-400 mt-2 block">@_user.OrderCount</span>
                </div>
                <div class="bg-slate-50 dark:bg-zinc-950/20 rounded-xl p-4 border border-slate-100 dark:border-zinc-800/40">
                    <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-zinc-500 block">Потрачено средств</span>
                    <span class="text-3xl font-extrabold text-slate-800 dark:text-zinc-200 mt-2 block">@_user.TotalSpent.ToString("N0") <span class="text-xs font-semibold">с.</span></span>
                </div>
            </div>
        </div>

        @* Панель управления аккаунтом *@
        <div class="md:col-span-4 space-y-6">
            @* Статус и блокировка *@
            <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-2xl p-6 shadow-sm theme-transition">
                <h3 class="text-sm font-bold text-slate-800 dark:text-zinc-200 mb-4 flex items-center gap-2">
                    <LucideIcon Name="shield" Class="w-4 h-4 text-indigo-500" />
                    <span>Безопасность</span>
                </h3>

                <div class="flex items-center justify-between mb-6">
                    <span class="text-xs font-semibold text-slate-500 dark:text-zinc-400">Статус аккаунта</span>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold @(_user.IsBlocked ? "bg-red-500/10 text-red-500" : "bg-emerald-500/10 text-emerald-500")">
                        @(_user.IsBlocked ? "Заблокирован" : "Активен")
                    </span>
                </div>

                @if (_user.IsBlocked)
                {
                    <button @onclick="Unblock" 
                            class="w-full py-2.5 bg-emerald-50 hover:bg-emerald-100 dark:bg-emerald-950/20 dark:hover:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-xl text-xs font-semibold shadow-sm transition-colors flex items-center justify-center gap-1.5">
                        <LucideIcon Name="lock-open" Class="w-4 h-4" />
                        <span>Разблокировать аккаунт</span>
                    </button>
                }
                else
                {
                    <button @onclick="Block" 
                            class="w-full py-2.5 bg-red-50 hover:bg-red-100 dark:bg-red-950/20 dark:hover:bg-red-900/20 border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 rounded-xl text-xs font-semibold shadow-sm transition-colors flex items-center justify-center gap-1.5">
                        <LucideIcon Name="lock" Class="w-4 h-4" />
                        <span>Заблокировать аккаунт</span>
                    </button>
                }
            </div>

            @* Изменение роли *@
            <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-2xl p-6 shadow-sm theme-transition">
                <h3 class="text-sm font-bold text-slate-800 dark:text-zinc-200 mb-4 flex items-center gap-2">
                    <LucideIcon Name="key" Class="w-4 h-4 text-indigo-500" />
                    <span>Ролевой доступ</span>
                </h3>

                <div class="space-y-4">
                    <MudSelect T="string" @bind-Value="_newRole" Label="Роль пользователя" Variant="Variant.Outlined" Class="mb-3">
                        <MudSelectItem T="string" Value="@("Customer")">Customer</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Admin")">Admin</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SuperAdmin")">SuperAdmin</MudSelectItem>
                    </MudSelect>

                    <button @onclick="ChangeRole" disabled="@(_newRole == _user.Role)"
                            class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 text-white rounded-xl text-xs font-semibold shadow-sm transition-colors flex items-center justify-center gap-1.5 h-11">
                        <span>Обновить права</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private bool _loading = true;
    private UserDto? _user;
    private string _newRole = "";

    protected override async Task OnInitializedAsync()
    {
        _user = await UserService.GetUserAsync(Id);
        _newRole = _user?.Role ?? "Customer";
        _loading = false;
    }

    private async Task Block()
    {
        if (!await DialogHelper.ConfirmAsync($"Заблокировать аккаунт {_user?.Phone}?")) return;
        var ok = await UserService.BlockUserAsync(Id);
        Snackbar.Add(ok ? "Пользователь заблокирован" : "Ошибка", ok ? Severity.Success : Severity.Error);
        if (ok) { _user!.IsBlocked = true; StateHasChanged(); }
    }

    private async Task Unblock()
    {
        var ok = await UserService.UnblockUserAsync(Id);
        Snackbar.Add(ok ? "Пользователь разблокирован" : "Ошибка", ok ? Severity.Success : Severity.Error);
        if (ok) { _user!.IsBlocked = false; StateHasChanged(); }
    }

    private async Task ChangeRole()
    {
        var ok = await UserService.ChangeRoleAsync(Id, _newRole);
        Snackbar.Add(ok ? $"Роль успешно изменена на {_newRole}" : "Ошибка", ok ? Severity.Success : Severity.Error);
        if (ok) { _user!.Role = _newRole; StateHasChanged(); }
    }

    private static string GetRoleBadgeClass(string role) => role switch
    {
        "SuperAdmin" => "bg-emerald-500/10 text-emerald-500",
        "Admin" => "bg-violet-500/10 text-violet-500",
        _ => "bg-slate-500/10 text-slate-400"
    };
}
