@page "/reviews"
@attribute [Authorize(Roles = "Admin,SuperAdmin")]

@inject ReviewService ReviewService
@inject ISnackbar Snackbar
@inject DialogHelper DialogHelper

<PageTitle>FlowerHouse — Модерация отзывов</PageTitle>

<PageHeader Title="Модерация отзывов" Subtitle="Одобрение и отклонение отзывов клиентов о товарах" />

<div class="flex border-b border-slate-200 dark:border-zinc-800 mb-6 select-none">
    <button @onclick="() => OnTabChanged(0)" 
            class="px-5 py-2.5 text-xs font-semibold border-b-2 -mb-[2px] transition-colors @(_activeTab == 0 ? "border-indigo-600 text-indigo-600 dark:border-violet-400 dark:text-violet-400" : "border-transparent text-slate-500 dark:text-zinc-400 hover:text-slate-800 dark:hover:text-zinc-200")">
        Ожидают
    </button>
    <button @onclick="() => OnTabChanged(1)" 
            class="px-5 py-2.5 text-xs font-semibold border-b-2 -mb-[2px] transition-colors @(_activeTab == 1 ? "border-indigo-600 text-indigo-600 dark:border-violet-400 dark:text-violet-400" : "border-transparent text-slate-500 dark:text-zinc-400 hover:text-slate-800 dark:hover:text-zinc-200")">
        Одобренные
    </button>
    <button @onclick="() => OnTabChanged(2)" 
            class="px-5 py-2.5 text-xs font-semibold border-b-2 -mb-[2px] transition-colors @(_activeTab == 2 ? "border-indigo-600 text-indigo-600 dark:border-violet-400 dark:text-violet-400" : "border-transparent text-slate-500 dark:text-zinc-400 hover:text-slate-800 dark:hover:text-zinc-200")">
        Отклонённые
    </button>
</div>

<div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl overflow-hidden shadow-sm theme-transition">
    <UiTable Items="@_reviews" TItem="ReviewDto" IsLoading="@_loading" 
             CurrentPage="@_currentPage" TotalPages="@_totalPages" OnPageChanged="OnPageChanged"
             ColSpan="@(_currentStatus == "Pending" ? 6 : 5)">
        <HeaderTemplate>
            <th class="p-4">Продукт</th>
            <th class="p-4">Автор</th>
            <th class="p-4 w-36">Рейтинг</th>
            <th class="p-4">Текст отзыва</th>
            <th class="p-4 w-36">Дата</th>
            @if (_currentStatus == "Pending")
            {
                <th class="p-4 w-48 text-center">Действия</th>
            }
        </HeaderTemplate>
        <RowTemplate>
            <td class="p-4 font-semibold text-slate-800 dark:text-zinc-200">@context.ProductName</td>
            <td class="p-4">
                <div class="flex flex-col">
                    <span class="font-semibold text-slate-800 dark:text-zinc-200">@context.UserName</span>
                    <span class="text-[10px] text-slate-400 dark:text-zinc-500">@context.UserPhone</span>
                </div>
            </td>
            <td class="p-4">
                <div class="flex items-center gap-0.5 text-amber-400">
                    @for (int s = 1; s <= 5; s++)
                    {
                        var starIdx = s;
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 @(starIdx <= context.Rating ? "fill-amber-400 text-amber-400" : "text-slate-200 dark:text-zinc-800")" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                    }
                </div>
            </td>
            <td class="p-4">
                <p class="max-w-xs md:max-w-md truncate text-slate-600 dark:text-zinc-300 font-medium">
                    @(context.Text ?? "—")
                </p>
            </td>
            <td class="p-4 font-medium text-slate-500 dark:text-zinc-400">@context.CreatedAt.ToString("dd.MM.yyyy")</td>
            @if (_currentStatus == "Pending")
            {
                <td class="p-4">
                    <div class="flex items-center justify-center gap-2">
                        <button @onclick="() => Approve(context)" 
                                class="px-2.5 py-1 bg-emerald-500/10 text-emerald-600 hover:bg-emerald-500/20 rounded text-xs font-semibold transition-colors flex items-center gap-1">
                            <LucideIcon Name="check" Class="w-3.5 h-3.5" />
                            <span>Одобрить</span>
                        </button>
                        <button @onclick="() => Reject(context)" 
                                class="px-2.5 py-1 bg-rose-500/10 text-rose-600 hover:bg-rose-500/20 rounded text-xs font-semibold transition-colors flex items-center gap-1">
                            <LucideIcon Name="x" Class="w-3.5 h-3.5" />
                            <span>Отклонить</span>
                        </button>
                    </div>
                </td>
            }
        </RowTemplate>
    </UiTable>
</div>

@code {
    private bool _loading = true;
    private List<ReviewDto> _reviews = [];
    private int _currentPage = 1;
    private int _totalPages = 1;
    private const int PageSize = 10;

    private int _activeTab = 0;
    private string _currentStatus = "Pending";
    private readonly string[] _statuses = ["Pending", "Approved", "Rejected"];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataInternal();
    }

    private async Task LoadDataInternal()
    {
        _loading = true;
        var r = await ReviewService.GetReviewsAsync(_currentPage, PageSize, _currentStatus);
        _reviews = r?.Items ?? [];
        _totalPages = r != null ? (int)Math.Ceiling((double)r.TotalCount / PageSize) : 1;
        _loading = false;
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadDataInternal();
    }

    private async Task OnTabChanged(int index)
    {
        _activeTab = index;
        _currentStatus = _statuses[index];
        _currentPage = 1;
        await LoadDataInternal();
    }

    private async Task Approve(ReviewDto review)
    {
        var ok = await ReviewService.ApproveAsync(review.Id);
        Snackbar.Add(ok ? "Отзыв одобрен" : "Ошибка", ok ? Severity.Success : Severity.Error);
        if (ok) await LoadDataInternal();
    }

    private async Task Reject(ReviewDto review)
    {
        if (!await DialogHelper.ConfirmAsync("Отклонить этот отзыв?")) return;
        var ok = await ReviewService.RejectAsync(review.Id);
        Snackbar.Add(ok ? "Отзыв отклонён" : "Ошибка", ok ? Severity.Success : Severity.Error);
        if (ok) await LoadDataInternal();
    }
}
