@page "/products"
@attribute [Authorize(Roles = "Admin,SuperAdmin")]

@inject ProductService ProductService
@inject ISnackbar Snackbar
@inject DialogHelper DialogHelper
@inject NavigationManager Navigation

<PageTitle>FlowerHouse — Продукты</PageTitle>

@* --- Header --- *@
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 select-none">
    <div>
        <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-zinc-50">Каталог букетов</h1>
        <p class="text-xs text-slate-500 dark:text-zinc-400">Управление цветочными композициями, ценами и категориями</p>
    </div>
    
    <div class="flex gap-2 shrink-0">
        <a href="products/new" 
           class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-semibold shadow-sm transition-colors flex items-center gap-1.5">
            <LucideIcon Name="plus" Class="w-4 h-4" />
            <span>Создать продукт</span>
        </a>
    </div>
</div>

@* --- Фильтры --- *@
<div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-4 shadow-sm mb-6 flex flex-col md:flex-row gap-4 items-end theme-transition">
    @* Поиск *@
    <div class="flex-grow flex flex-col gap-1.5 w-full md:w-auto">
        <label class="text-xs font-semibold text-slate-500 dark:text-zinc-400 select-none">Поиск по каталогу</label>
        <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 dark:text-zinc-500">
                <LucideIcon Name="search" Class="w-4 h-4" />
            </span>
            <input type="text" @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" placeholder="Введите название букета..."
                   class="w-full pl-9 pr-3 py-2 text-xs bg-slate-50 dark:bg-zinc-950 border border-slate-200 dark:border-zinc-800 rounded-lg outline-none text-slate-900 dark:text-zinc-100 placeholder-slate-400 focus:border-indigo-500 transition-colors" />
        </div>
    </div>

    @* Категория *@
    <div class="flex flex-col gap-1.5 w-full md:w-64">
        <label class="text-xs font-semibold text-slate-500 dark:text-zinc-400 select-none">Категория</label>
        <select @bind="_categoryId"
                class="w-full px-3 py-2 text-xs bg-slate-50 dark:bg-zinc-950 border border-slate-200 dark:border-zinc-800 rounded-lg outline-none text-slate-900 dark:text-zinc-100 transition-colors">
            <option value="">Все категории</option>
            @if (_categories != null)
            {
                @foreach (var cat in _categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
    </div>

    @* Кнопка очистки / поиска *@
    <div class="flex gap-2 w-full md:w-auto">
        <button @onclick="ApplyFiltersAsync" 
                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-semibold shadow-sm transition-colors flex items-center justify-center gap-1.5 h-9 shrink-0 flex-1 md:flex-none">
            <span>Применить</span>
        </button>
        <button @onclick="ClearFiltersAsync" 
                class="px-3 py-2 border border-slate-200 dark:border-zinc-800 rounded-lg text-xs font-semibold text-slate-600 dark:text-zinc-300 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors h-9 shrink-0">
            Сбросить
        </button>
    </div>
</div>

@* --- Таблица продуктов --- *@
<div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl overflow-hidden shadow-sm theme-transition">
    <UiTable Items="@_products" TItem="ProductDto" 
             IsLoading="@_loading" 
             CurrentPage="@_currentPage" 
             TotalPages="@_totalPages" 
             OnPageChanged="OnPageChangedAsync"
             ColSpan="6">
        <HeaderTemplate>
            <th class="p-4 w-20">Фото</th>
            <th class="p-4">Название</th>
            <th class="p-4 w-36">Цена</th>
            <th class="p-4 w-44">Категория</th>
            <th class="p-4 w-28 text-center">Активен</th>
            <th class="p-4 w-28 text-center">Действия</th>
        </HeaderTemplate>
        <RowTemplate>
            <td class="p-4">
                @if (context.Images?.Any() == true)
                {
                    <img src="@context.Images.First().Url" alt="@context.Name" class="w-10 h-10 object-cover rounded-md border border-slate-100 dark:border-zinc-800" />
                }
                else
                {
                    <div class="w-10 h-10 bg-slate-100 dark:bg-zinc-800 rounded-md flex items-center justify-center text-slate-400">
                        <LucideIcon Name="image" Class="w-4 h-4" />
                    </div>
                }
            </td>
            <td class="p-4">
                <a href="products/@context.Id/edit" class="font-semibold text-slate-800 dark:text-zinc-200 hover:text-indigo-600 hover:underline">@context.Name</a>
                <div class="text-[10px] text-slate-400 dark:text-zinc-500 mt-0.5">@context.Slug</div>
            </td>
            <td class="p-4">
                @if (context.DiscountPrice.HasValue)
                {
                    <div class="font-bold text-rose-500">@context.DiscountPrice.Value.ToString("N0") с.</div>
                    <div class="text-[10px] text-slate-400 dark:text-zinc-500 line-through">@context.Price.ToString("N0") с.</div>
                }
                else
                {
                    <div class="font-semibold text-slate-800 dark:text-zinc-200">@context.Price.ToString("N0") с.</div>
                }
            </td>
            <td class="p-4 select-none">
                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-indigo-50 dark:bg-indigo-950/20 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-950/30">
                    @context.CategoryName
                </span>
            </td>
            <td class="p-4 text-center select-none">
                @if (context.IsActive)
                {
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-50 dark:bg-emerald-950/20 text-emerald-600 dark:text-emerald-400 border border-emerald-100 dark:border-emerald-950/30">
                        Активен
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-slate-50 dark:bg-zinc-800 text-slate-400 dark:text-zinc-500 border border-slate-100 dark:border-zinc-800">
                        Черновик
                    </span>
                }
            </td>
            <td class="p-4 text-center select-none">
                <div class="flex items-center justify-center gap-1">
                    <a href="products/@context.Id/edit" class="p-1.5 text-slate-500 hover:text-indigo-600 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-md transition-colors" title="Редактировать">
                        <LucideIcon Name="edit" Class="w-3.5 h-3.5" />
                    </a>
                    <button @onclick="() => DeleteProduct(context)" @onclick:stopPropagation="true" class="p-1.5 text-slate-500 hover:text-rose-600 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-md transition-colors" title="Удалить">
                        <LucideIcon Name="trash" Class="w-3.5 h-3.5" />
                    </button>
                </div>
            </td>
        </RowTemplate>
    </UiTable>
</div>

@code {
    private bool _loading = true;
    private string _search = "";
    private int? _categoryId;
    private List<CategoryDto>? _categories;

    private int _currentPage = 1;
    private int _pageSize = 15;
    private int _totalPages = 1;

    private List<ProductDto> _products = new();

    protected override async Task OnInitializedAsync()
    {
        _categories = await ProductService.GetCategoriesAsync();
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await ProductService.GetProductsAsync(
                page: _currentPage,
                pageSize: _pageSize,
                search: string.IsNullOrWhiteSpace(_search) ? null : _search,
                categoryId: _categoryId);

            if (result != null)
            {
                _products = result.Items ?? new();
                _totalPages = (int)Math.Ceiling((double)result.TotalCount / _pageSize);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки каталога: {ex.Message}", Severity.Error);
            _products = new();
            _totalPages = 1;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _currentPage = 1;
            await LoadProductsAsync();
        }
    }

    private async Task ApplyFiltersAsync()
    {
        _currentPage = 1;
        await LoadProductsAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _search = "";
        _categoryId = null;
        _currentPage = 1;
        await LoadProductsAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        await LoadProductsAsync();
    }

    private async Task DeleteProduct(ProductDto product)
    {
        if (!await DialogHelper.ConfirmAsync($"Вы действительно хотите удалить букет \"{product.Name}\"?")) return;
        
        try
        {
            var ok = await ProductService.DeleteProductAsync(product.Id);
            if (ok)
            {
                Snackbar.Add("Продукт успешно удален из каталога", Severity.Success);
                await LoadProductsAsync();
            }
            else
            {
                Snackbar.Add("Ошибка при удалении продукта", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
    }
}
