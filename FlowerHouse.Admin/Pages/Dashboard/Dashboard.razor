@page "/"
@attribute [Authorize(Roles = "Admin,SuperAdmin")]

@inject DashboardService DashboardService
@inject OrderService OrderService
@inject NavigationManager Navigation

<PageTitle>FlowerHouse — Дашборд</PageTitle>

@* --- Title & Organization Context Switcher --- *@
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 select-none">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-zinc-50">Панель управления</h1>
        <p class="text-xs text-slate-500 dark:text-zinc-400">Обзор ключевых показателей эффективности магазина</p>
    </div>
    
    <AuthorizeView Roles="SuperAdmin">
        <div class="flex items-center gap-3">
            <span class="text-xs text-slate-400 dark:text-zinc-500">Контекст:</span>
            <TenantSwitcher />
        </div>
    </AuthorizeView>
</div>

@* === KPI-карточки === *@
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    @if (_loading || _stats == null)
    {
        @for (var i = 0; i < 4; i++)
        {
            <div class="h-28 rounded-xl bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 p-5 flex flex-col justify-between skeleton">
                <div class="h-4 w-2/3 bg-slate-200 dark:bg-zinc-800 rounded"></div>
                <div class="h-8 w-1/2 bg-slate-200 dark:bg-zinc-800 rounded"></div>
            </div>
        }
    }
    else
    {
        @* Заказы сегодня *@
        <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 flex flex-col justify-between shadow-sm theme-transition">
            <div class="flex items-center justify-between text-slate-500 dark:text-zinc-400">
                <span class="text-xs font-semibold uppercase tracking-wider">Заказов сегодня</span>
                <LucideIcon Name="shopping-bag" Class="w-4 h-4 text-indigo-500 dark:text-indigo-400" />
            </div>
            <div class="flex items-baseline gap-2 mt-3">
                <span class="text-2xl font-bold text-slate-900 dark:text-zinc-50">@_stats.OrdersToday</span>
                <div class="flex items-center text-[10px] font-bold @(GetTrendColorClass(_stats.OrdersTodayChange))">
                    <span>@FormatChange(_stats.OrdersTodayChange)</span>
                </div>
            </div>
            <div class="text-[10px] text-slate-400 dark:text-zinc-500 mt-1">
                сравнение со вчерашним днем
            </div>
        </div>

        @* Выручка *@
        <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 flex flex-col justify-between shadow-sm theme-transition">
            <div class="flex items-center justify-between text-slate-500 dark:text-zinc-400">
                <span class="text-xs font-semibold uppercase tracking-wider">Выручка сегодня</span>
                <LucideIcon Name="percent" Class="w-4 h-4 text-emerald-500 dark:text-emerald-400" />
            </div>
            <div class="flex items-baseline gap-2 mt-3">
                <span class="text-2xl font-bold text-slate-900 dark:text-zinc-50">@FormatMoney(_stats.RevenueToday)</span>
                <div class="flex items-center text-[10px] font-bold @(GetTrendColorClass(_stats.RevenueTodayChange))">
                    <span>@FormatChange(_stats.RevenueTodayChange)</span>
                </div>
            </div>
            <div class="text-[10px] text-slate-400 dark:text-zinc-500 mt-1">
                сравнение со вчерашним днем
            </div>
        </div>

        @* Новые клиенты *@
        <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 flex flex-col justify-between shadow-sm theme-transition">
            <div class="flex items-center justify-between text-slate-500 dark:text-zinc-400">
                <span class="text-xs font-semibold uppercase tracking-wider">Новых клиентов</span>
                <LucideIcon Name="users" Class="w-4 h-4 text-rose-500 dark:text-rose-400" />
            </div>
            <div class="flex items-baseline gap-2 mt-3">
                <span class="text-2xl font-bold text-slate-900 dark:text-zinc-50">@_stats.NewCustomers</span>
                <span class="text-[10px] text-emerald-500 font-semibold">+12%</span>
            </div>
            <div class="text-[10px] text-slate-400 dark:text-zinc-500 mt-1">
                новые регистрации за сегодня
            </div>
        </div>

        @* Средний чек *@
        <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 flex flex-col justify-between shadow-sm theme-transition">
            <div class="flex items-center justify-between text-slate-500 dark:text-zinc-400">
                <span class="text-xs font-semibold uppercase tracking-wider">Средний чек</span>
                <LucideIcon Name="gift" Class="w-4 h-4 text-blue-500 dark:text-blue-400" />
            </div>
            <div class="flex items-baseline gap-2 mt-3">
                <span class="text-2xl font-bold text-slate-900 dark:text-zinc-50">@FormatMoney(_stats.AverageCheck)</span>
                <span class="text-[10px] text-slate-400 dark:text-zinc-500 font-normal">TJS</span>
            </div>
            <div class="text-[10px] text-slate-400 dark:text-zinc-500 mt-1">
                средняя стоимость заказа
            </div>
        </div>
    }
</div>

@* === Графики и таблицы === *@
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    @* График заказов *@
    <div class="lg:col-span-2 bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 shadow-sm flex flex-col justify-between theme-transition">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-sm font-semibold text-slate-900 dark:text-zinc-100">Статистика продаж</h3>
            <span class="text-xs text-slate-400 dark:text-zinc-500">За последние 30 дней</span>
        </div>
        <div class="flex-1 min-h-[300px]">
            <OrdersChart />
        </div>
    </div>

    @* Топ продукты *@
    <div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 shadow-sm theme-transition flex flex-col">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-zinc-100 mb-4">Популярные букеты</h3>
        
        <div class="flex-grow flex flex-col gap-3">
            @if (_topProducts != null)
            {
                @foreach (var (product, idx) in _topProducts.Select((p, i) => (p, i)))
                {
                    <div class="flex items-center gap-3 py-1 border-b border-slate-100 dark:border-zinc-800 last:border-0 pb-3 last:pb-0">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs select-none shrink-0 text-white"
                             style="background: linear-gradient(135deg, @GetGradient(idx));">
                            @(idx + 1)
                        </div>
                        <div class="flex-grow min-w-0">
                            <h4 class="text-xs font-semibold text-slate-800 dark:text-zinc-200 truncate">@product.Name</h4>
                            <span class="text-[10px] text-slate-400 dark:text-zinc-500">@product.SoldCount продано</span>
                        </div>
                        <div class="text-xs font-bold text-indigo-600 dark:text-indigo-400 shrink-0">
                            @FormatMoney(product.Revenue)
                        </div>
                    </div>
                }
            }
            else
            {
                @for (var i = 0; i < 5; i++)
                {
                    <div class="h-12 rounded-lg bg-slate-100 dark:bg-zinc-800 skeleton w-full"></div>
                }
            }
        </div>
    </div>
</div>

@* === Последние заказы === *@
<div class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 shadow-sm theme-transition">
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-zinc-100">Последние заказы</h3>
        <a href="orders" class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:underline flex items-center gap-1">
            <span>Все заказы</span>
            <LucideIcon Name="chevron-right" Class="w-3.5 h-3.5" />
        </a>
    </div>

    @if (_recentOrders != null)
    {
        <UiTable Items="@_recentOrders" TItem="OrderDto" ShowPagination="false" ColSpan="5" IsLoading="false">
            <HeaderTemplate>
                <th class="p-4 w-28">№ Заказа</th>
                <th class="p-4">Клиент</th>
                <th class="p-4 w-32">Сумма</th>
                <th class="p-4 w-36">Статус</th>
                <th class="p-4 w-36">Дата</th>
            </HeaderTemplate>
            <RowTemplate>
                <td class="p-4 font-semibold text-indigo-600 dark:text-indigo-400">
                    <a href="orders/@context.Id">@context.OrderNumber</a>
                </td>
                <td class="p-4">
                    <div class="font-medium text-slate-800 dark:text-zinc-200">@context.CustomerName</div>
                    <div class="text-[10px] text-slate-400 dark:text-zinc-500">@context.CustomerPhone</div>
                </td>
                <td class="p-4 font-bold text-slate-900 dark:text-zinc-100">
                    @FormatMoney(context.Total)
                </td>
                <td class="p-4">
                    <StatusBadge Status="@context.Status" />
                </td>
                <td class="p-4">
                    <div class="text-slate-800 dark:text-zinc-200">@context.CreatedAt.ToString("dd.MM.yyyy")</div>
                    <div class="text-[10px] text-slate-400 dark:text-zinc-500">@context.CreatedAt.ToString("HH:mm")</div>
                </td>
            </RowTemplate>
        </UiTable>
    }
    else
    {
        <div class="h-40 rounded-xl bg-slate-100 dark:bg-zinc-800 skeleton w-full"></div>
    }
</div>

@code {
    private bool _loading = true;
    private DashboardStatsDto? _stats;
    private List<TopProductDto>? _topProducts;
    private List<OrderDto>? _recentOrders;

    protected override async Task OnInitializedAsync()
    {
        var statsTask = DashboardService.GetStatsAsync();
        var topTask = DashboardService.GetTopProductsAsync(5);
        var ordersTask = DashboardService.GetRecentOrdersAsync(5);

        await Task.WhenAll(statsTask, topTask, ordersTask);

        _stats = statsTask.Result;
        _topProducts = topTask.Result;

        var ordersResult = ordersTask.Result;
        _recentOrders = ordersResult?.Items;

        _loading = false;
    }

    private static string FormatMoney(decimal amount) =>
        $"{amount:N0} с.";

    private static string FormatChange(decimal change) =>
        change >= 0 ? $"+{change:N1}%" : $"{change:N1}%";

    private static string GetTrendColorClass(decimal change) =>
        change >= 0 ? "text-emerald-500" : "text-rose-500";

    private static string GetGradient(int index) => index switch
    {
        0 => "#7C3AED, #A78BFA",
        1 => "#EC4899, #F472B6",
        2 => "#10B981, #34D399",
        3 => "#F59E0B, #FBBF24",
        4 => "#3B82F6, #60A5FA",
        _ => "#64748B, #94A3B8"
    };
}
