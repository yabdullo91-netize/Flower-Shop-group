@inherits LayoutComponentBase
@inject JwtAuthStateProvider AuthState
@inject NavigationManager Navigation
@inject DialogHelper DialogHelper
@inject LocalStorageService LocalStorage
@inject IJSRuntime Js

<div class="flex h-screen overflow-hidden text-sm bg-slate-50 dark:bg-[#09090b] text-slate-900 dark:text-zinc-100 theme-transition font-sans">
    
    @* --- Sidebar --- *@
    <aside class="flex flex-col h-full bg-zinc-950 border-r border-zinc-800 text-zinc-400 select-none transition-all duration-300 z-30
                  @( _sidebarCollapsed ? "w-16" : "w-64" ) @( _sidebarMobileOpen ? "fixed inset-y-0 left-0" : "hidden md:flex" )">
        
        @* Logo / Brand *@
        <div class="flex items-center justify-between h-14 px-4 border-b border-zinc-800">
            <div class="flex items-center gap-3 overflow-hidden">
                <span class="text-xl shrink-0">🌸</span>
                @if (!_sidebarCollapsed)
                {
                    <div class="flex flex-col leading-tight">
                        <span class="font-bold text-zinc-100 text-base">FlowerHouse</span>
                        <span class="text-[10px] text-zinc-500 uppercase tracking-wider">Панель</span>
                    </div>
                }
            </div>
            @if (!_sidebarCollapsed)
            {
                <button @onclick="ToggleSidebar" class="p-1 text-zinc-500 hover:text-zinc-300 rounded hover:bg-zinc-900 md:block hidden">
                    <LucideIcon Name="chevron-left" Class="w-4 h-4" />
                </button>
            }
        </div>

        @* Navigation Menu *@
        <div class="flex-1 overflow-y-auto py-4">
            <NavMenu SidebarCollapsed="@_sidebarCollapsed" />
        </div>

        @* Sidebar Footer (User / LogOut) *@
        <div class="p-4 border-t border-zinc-800">
            <AuthorizeView>
                <Authorized>
                    <div class="flex items-center gap-3 overflow-hidden">
                        <div class="w-8 h-8 rounded-full bg-brand flex items-center justify-center text-white font-bold text-xs uppercase shrink-0">
                            @(context.User.Identity?.Name?[..Math.Min(2, context.User.Identity.Name.Length)] ?? "AD")
                        </div>
                        @if (!_sidebarCollapsed)
                        {
                            <div class="flex-1 min-w-0 leading-tight">
                                <p class="text-zinc-200 font-medium truncate text-xs">@context.User.Identity?.Name</p>
                                <p class="text-zinc-500 text-[10px] truncate uppercase tracking-wider">
                                    @context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                </p>
                            </div>
                            <button @onclick="LogoutAsync" class="p-1.5 text-zinc-500 hover:text-red-400 hover:bg-zinc-900 rounded shrink-0">
                                <LucideIcon Name="log-out" Class="w-4 h-4" />
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    @* Mobile Sidebar Backdrop *@
    @if (_sidebarMobileOpen)
    {
        <div @onclick="ToggleMobileSidebar" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-20 md:hidden"></div>
    }

    @* --- Main Content Area --- *@
    <div class="flex flex-col flex-1 h-full overflow-hidden">
        
        @* --- Header --- *@
        <header class="flex items-center justify-between h-14 px-6 border-b border-gray-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 theme-transition z-10 shrink-0">
            
            @* Left: Toggle button + Breadcrumbs + SuperAdmin Indicator *@
            <div class="flex items-center gap-4">
                <button @onclick="ToggleMobileSidebar" class="md:hidden p-1.5 text-slate-500 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded">
                    <LucideIcon Name="filter" Class="w-5 h-5 rotate-90" />
                </button>
                <button @onclick="ToggleSidebar" class="hidden md:block p-1.5 text-slate-500 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded">
                    <LucideIcon Name="filter" Class="w-5 h-5 rotate-90" />
                </button>

                @* Breadcrumbs *@
                <div class="flex items-center gap-2 text-xs text-slate-400 dark:text-zinc-500 font-medium md:flex hidden">
                    <span>FlowerHouse</span>
                    <LucideIcon Name="chevron-right" Class="w-3 h-3" />
                    <span class="text-slate-700 dark:text-zinc-300">@_currentPathTitle</span>
                </div>

                @* SuperAdmin Badge *@
                <AuthorizeView Roles="SuperAdmin">
                    <span class="px-2 py-0.5 text-[10px] font-bold bg-emerald-500/15 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 rounded-full tracking-wider uppercase">
                        SUPER ADMIN
                    </span>
                </AuthorizeView>
            </div>

            @* Right: Actions (Search, Theme, Notify, Dropdown) *@
            <div class="flex items-center gap-4">
                
                @* Search Bar *@
                <div class="relative max-w-xs md:block hidden">
                    <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 dark:text-zinc-500">
                        <LucideIcon Name="search" Class="w-4 h-4" />
                    </span>
                    <input type="text" placeholder="Быстрый поиск..." 
                           class="w-48 xl:w-64 pl-9 pr-3 py-1.5 text-xs bg-slate-100 dark:bg-zinc-800 border border-transparent focus:border-slate-300 dark:focus:border-zinc-700 rounded-lg outline-none text-slate-900 dark:text-zinc-100 placeholder-slate-400 focus:bg-white dark:focus:bg-zinc-900 transition-all duration-200" />
                </div>

                @* Theme Toggle *@
                <button @onclick="ToggleThemeAsync" class="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-lg">
                    @if (_isDarkMode)
                    {
                        <LucideIcon Name="sun" Class="w-4 h-4 text-amber-400" />
                    }
                    else
                    {
                        <LucideIcon Name="moon" Class="w-4 h-4 text-slate-600" />
                    }
                </button>

                @* Notification Bell *@
                <button class="relative p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-lg">
                    <LucideIcon Name="bell" Class="w-4 h-4" />
                    <span class="absolute top-1 right-1 w-2.5 h-2.5 bg-rose-500 border-2 border-white dark:border-zinc-900 rounded-full"></span>
                </button>

                @* User Menu Dropdown *@
                <div class="relative">
                    <button @onclick="ToggleProfileMenu" class="flex items-center gap-1.5 focus:outline-none">
                        <div class="w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold text-xs uppercase">
                            AD
                        </div>
                    </button>
                    
                    @if (_profileMenuOpen)
                    {
                        <div class="absolute right-0 mt-2 w-48 bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-lg shadow-lg py-1 z-50 text-slate-700 dark:text-zinc-300">
                            <div class="px-4 py-2 border-b border-slate-100 dark:border-zinc-800 text-xs">
                                <p class="font-medium text-slate-900 dark:text-zinc-100">Администратор</p>
                                <p class="text-slate-400 dark:text-zinc-500 truncate">admin@flowerhouse.tj</p>
                            </div>
                            <button @onclick="LogoutAsync" class="flex items-center gap-2 w-full px-4 py-2 text-left text-xs hover:bg-slate-50 dark:hover:bg-zinc-800 text-rose-500">
                                <LucideIcon Name="log-out" Class="w-4 h-4" />
                                Выйти из системы
                            </button>
                        </div>
                        <div @onclick="CloseProfileMenu" class="fixed inset-0 z-40"></div>
                    }
                </div>
            </div>
        </header>

        @* --- Main Content Body --- *@
        <main class="flex-1 overflow-y-auto p-6 bg-slate-50 dark:bg-zinc-950 theme-transition">
            <div class="max-w-[1600px] mx-auto page-enter">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private bool _sidebarCollapsed = false;
    private bool _sidebarMobileOpen = false;
    private bool _profileMenuOpen = false;
    private bool _isDarkMode = false;
    private string _currentPathTitle = "Панель управления";

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdatePathTitle(Navigation.Uri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedTheme = await LocalStorage.GetItemAsync("theme");
            if (savedTheme == "dark")
            {
                _isDarkMode = true;
                await Js.InvokeVoidAsync("themeHelper.setTheme", "dark");
                StateHasChanged();
            }
            else if (savedTheme == "light")
            {
                _isDarkMode = false;
                await Js.InvokeVoidAsync("themeHelper.setTheme", "light");
                StateHasChanged();
            }
            else
            {
                // Init from preferences
                var systemTheme = await Js.InvokeAsync<string>("themeHelper.initTheme");
                _isDarkMode = systemTheme == "dark";
                StateHasChanged();
            }
        }
    }

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;
    private void ToggleMobileSidebar() => _sidebarMobileOpen = !_sidebarMobileOpen;
    private void ToggleProfileMenu() => _profileMenuOpen = !_profileMenuOpen;
    private void CloseProfileMenu() => _profileMenuOpen = false;

    private async Task ToggleThemeAsync()
    {
        _isDarkMode = !_isDarkMode;
        var newTheme = _isDarkMode ? "dark" : "light";
        await LocalStorage.SetItemAsync("theme", newTheme);
        await Js.InvokeVoidAsync("themeHelper.setTheme", newTheme);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdatePathTitle(e.Location);
        _sidebarMobileOpen = false;
        _profileMenuOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void UpdatePathTitle(string uri)
    {
        var relative = Navigation.ToBaseRelativePath(uri).Split('?')[0].ToLowerInvariant();
        _currentPathTitle = relative switch
        {
            "" => "Дашборд",
            "orders" => "Заказы",
            "products" => "Каталог товаров",
            "addons" => "Аддоны и сопутствующие",
            "postcards" => "Открытки",
            "reviews" => "Отзывы",
            "loyalty" => "Программа лояльности",
            "delivery" => "Доставка",
            "users" => "Пользователи",
            "promo-codes" => "Промокоды",
            "banners" => "Баннеры",
            "settings" => "Настройки системы",
            "audit-log" => "Журнал аудита",
            "push" => "Push-рассылки",
            "admin-users" => "Аккаунты администраторов",
            _ => "Панель управления"
        };
    }

    private async Task LogoutAsync()
    {
        if (!await DialogHelper.ConfirmAsync("Вы уверены, что хотите выйти из системы?", "Выход")) return;
        await AuthState.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
