@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="@_isDarkMode" Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:80vh">
                            <MudCard Class="pa-8 text-center" Elevation="4" Style="border-radius:16px">
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Error" />
                                <MudText Typo="Typo.h5" Class="mt-4 mb-2" Style="font-weight:700">Доступ запрещён</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Secondary">
                                    У вас нет прав для просмотра этой страницы.
                                </MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-6"
                                           Href="/" StartIcon="@Icons.Material.Filled.Home">
                                    На главную
                                </MudButton>
                            </MudCard>
                        </MudContainer>
                    }
                </NotAuthorized>
                <Authorizing>
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>404 — Не найдено</PageTitle>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:80vh">
                    <MudCard Class="pa-8 text-center" Elevation="4" Style="border-radius:16px">
                        <MudText Typo="Typo.h1" Color="Color.Primary" Style="font-weight:900;font-size:72px">404</MudText>
                        <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight:700">Страница не найдена</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            Страница, которую вы ищете, не существует.
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-6"
                                   Href="/" StartIcon="@Icons.Material.Filled.Home">
                            На главную
                        </MudButton>
                    </MudCard>
                </MudContainer>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

