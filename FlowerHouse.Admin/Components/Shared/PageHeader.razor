@* Заголовок страницы с breadcrumbs и action-кнопками *@

<div class="flex flex-wrap items-center justify-between gap-4 mb-6 select-none">
    <div>
        @if (BreadcrumbItems?.Any() == true)
        {
            <MudBreadcrumbs Items="@BreadcrumbItems" Class="pa-0 mb-1"
                            Style="font-size: 13px;" />
        }
        <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -1px;" Class="text-slate-900 dark:text-zinc-50">
            @Title
        </MudText>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <p class="text-xs text-slate-500 dark:text-zinc-400 mt-1 font-medium">
                @Subtitle
            </p>
        }
    </div>

    @if (Actions != null)
    {
        <div class="flex items-center gap-2 shrink-0">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public List<BreadcrumbItem>? BreadcrumbItems { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
