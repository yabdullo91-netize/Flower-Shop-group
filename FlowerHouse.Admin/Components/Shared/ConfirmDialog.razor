@* Универсальное модальное подтверждение *@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
            <MudIcon Icon="@Icon" Color="@IconColor" />
            @Title
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudText Typo="Typo.body1" Class="mt-2">@Message</MudText>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton OnClick="Confirm" Variant="Variant.Filled" Color="@ConfirmColor"
                   StartIcon="@ConfirmIcon">
            @ConfirmText
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    [Parameter] public string Title { get; set; } = "Подтверждение";
    [Parameter] public string Message { get; set; } = "Вы уверены?";
    [Parameter] public string ConfirmText { get; set; } = "Подтвердить";
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Warning;
    [Parameter] public Color IconColor { get; set; } = Color.Warning;
    [Parameter] public Color ConfirmColor { get; set; } = Color.Primary;
    [Parameter] public string ConfirmIcon { get; set; } = Icons.Material.Filled.Check;

    private void Cancel() => MudDialog?.Cancel();
    private void Confirm() => MudDialog?.Close(DialogResult.Ok(true));
}
