@if (IsOpen)
{
    <div class="fixed inset-0 z-50 overflow-y-auto flex items-center justify-center p-4">
        @* Backdrop Blur *@
        <div @onclick="CloseModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity"></div>

        @* Modal Content Box *@
        <div class="relative bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl max-w-lg w-full overflow-hidden shadow-2xl transition-all transform scale-100 theme-transition flex flex-col max-h-[85vh] z-10">
            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-zinc-800">
                <h3 class="text-base font-semibold text-slate-900 dark:text-zinc-100">@Title</h3>
                <button @onclick="CloseModal" class="p-1 text-slate-400 hover:text-slate-600 dark:hover:text-zinc-200 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-md">
                    <LucideIcon Name="x" Class="w-4 h-4" />
                </button>
            </div>

            @* Body *@
            <div class="flex-1 overflow-y-auto px-6 py-4 text-sm text-slate-700 dark:text-zinc-300">
                @ChildContent
            </div>

            @* Footer *@
            @if (FooterContent != null)
            {
                <div class="px-6 py-4 border-t border-slate-200 dark:border-zinc-800 bg-slate-50 dark:bg-zinc-950/20 flex items-center justify-end gap-3 shrink-0">
                    @FooterContent
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string Title { get; set; } = "Модальное окно";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task CloseModal()
    {
        await OnClose.InvokeAsync();
    }
}
