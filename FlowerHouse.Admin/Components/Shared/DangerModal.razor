@if (IsOpen)
{
    <div class="fixed inset-0 z-50 overflow-y-auto flex items-center justify-center p-4">
        @* Backdrop *@
        <div @onclick="Cancel" class="fixed inset-0 bg-black/60 backdrop-blur-sm"></div>

        @* Modal Content Box *@
        <div class="relative bg-white dark:bg-zinc-900 border border-red-200 dark:border-red-950/30 rounded-xl max-w-md w-full overflow-hidden shadow-2xl transition-all transform scale-100 theme-transition flex flex-col z-10">
            @* Header *@
            <div class="flex items-center gap-3 px-6 py-4 border-b border-slate-200 dark:border-zinc-800 text-rose-600 dark:text-rose-400">
                <LucideIcon Name="alert-triangle" Class="w-5 h-5 shrink-0" />
                <h3 class="text-base font-semibold">Опасное действие!</h3>
            </div>

            @* Body *@
            <div class="px-6 py-4 text-xs flex flex-col gap-4 text-slate-700 dark:text-zinc-300">
                <p class="font-medium text-slate-900 dark:text-zinc-100 text-sm">
                    @Message
                </p>
                
                <div class="p-3 bg-red-50 dark:bg-red-950/20 border border-red-100 dark:border-red-950/30 text-red-600 dark:text-red-400 rounded-lg">
                    Это действие необратимо. Пожалуйста, убедитесь, что вы действительно хотите это сделать.
                </div>

                <div class="flex flex-col gap-1.5 mt-2">
                    <label class="text-slate-500 dark:text-zinc-400">
                        Для подтверждения введите слово <strong class="text-slate-800 dark:text-zinc-200">@ConfirmWord</strong>:
                    </label>
                    <input type="text" @bind="_inputValue" @bind:event="oninput" placeholder="Введите проверочное слово"
                           class="w-full px-3 py-2 border border-slate-200 dark:border-zinc-800 dark:bg-zinc-950 focus:border-red-500 rounded-lg outline-none text-slate-900 dark:text-zinc-100 text-xs transition-colors" />
                </div>
            </div>

            @* Footer *@
            <div class="px-6 py-4 border-t border-slate-200 dark:border-zinc-800 bg-slate-50 dark:bg-zinc-950/20 flex items-center justify-end gap-3">
                <button @onclick="Cancel" class="px-4 py-2 text-xs border border-slate-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 rounded-lg hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
                    Отмена
                </button>
                <button @onclick="Confirm" disabled="@(!IsInputValid)" 
                        class="px-4 py-2 text-xs font-semibold text-white bg-rose-600 hover:bg-rose-700 disabled:opacity-50 disabled:cursor-not-allowed rounded-lg transition-colors">
                    Подтвердить
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string Message { get; set; } = "Вы действительно хотите продолжить?";
    [Parameter] public string ConfirmWord { get; set; } = "УДАЛИТЬ";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _inputValue = "";

    private bool IsInputValid => string.Equals(_inputValue.Trim(), ConfirmWord, StringComparison.Ordinal);

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            _inputValue = ""; // Reset on close
        }
    }

    private async Task Confirm()
    {
        if (IsInputValid)
        {
            await OnConfirm.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }
}
